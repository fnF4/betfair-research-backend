# =====================================================
# Betfair Research Backend — environment configuration
# =====================================================
# Copy this file to backend/.env for local development, or set these as
# environment variables in the Render service dashboard for production.

# ---------- Betfair credentials (REQUIRED) ----------
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_APP_KEY=

# Certificate-based login (recommended for 24/7 production).
# If false, will use interactive username/password login.
BETFAIR_USE_CERTS=false
BETFAIR_CERT_PATH=
BETFAIR_KEY_PATH=

BETFAIR_LOCALE=IT
BETFAIR_COMMISSION=0.05

# ---------- Storage ----------
BETFAIR_DATA_DIR=./data

# ---------- Collector ----------
BETFAIR_EVENT_TYPE_IDS=1,2
BETFAIR_HORIZON_HOURS=72
BETFAIR_TIER_1_LIMIT=30
BETFAIR_TIER_2_LIMIT=0
BETFAIR_TIER_3_LIMIT=0
BETFAIR_MIN_TOTAL_MATCHED=1000
BETFAIR_CYCLE_SECONDS=45

# ---------- Detection ----------
BETFAIR_MIN_EDGE_NET=0.003
BETFAIR_SAFETY_MARGIN=1.5
BETFAIR_GHOST_MS=2000

# ---------- Paper trading ----------
BETFAIR_CAPITAL=10000
BETFAIR_PER_TRADE=500
BETFAIR_PAPER_MIN_EDGE=0.003
BETFAIR_PAPER_MIN_NOTIONAL=25
BETFAIR_MAX_HOLD_H=72
BETFAIR_ONLY_CATCHABLE=false

# ---------- Runtime ----------
BETFAIR_EXECUTION_MODE=paper
BETFAIR_KILL_SWITCH=false
BETFAIR_ADMIN_SECRET=change-me-to-a-random-string
BETFAIR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BETFAIR_LOG_LEVEL=INFO
BETFAIR_DISABLE_SCHEDULER=false
